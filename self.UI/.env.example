
# Copy this to .env and update values for your environment
# IMPORTANT: Never commit .env to git — it contains secrets

WEBUI_URL="https://chat.example.com"
ENV=dev
OFFLINE_MODE=true
GLOBAL_LOG_LEVEL=INFO
CUSTOM_NAME="Self.AI"
DEFAULT_LOCALE="en"
ENABLE_PERSISTENT_CONFIG=False


#############
#
# OAuth
#
#############

ENABLE_OAUTH_SIGNUP=true
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret-here
OPENID_PROVIDER_URL=https://auth.example.com/.well-known/openid-configuration
OPENID_REDIRECT_URI=https://chat.example.com/oauth/oidc/callback
OAUTH_PROVIDER_NAME=Auth
OAUTH_SCOPES="openid email profile"
OAUTH_EMAIL_CLAIM=email
OAUTH_USERNAME_CLAIM=preferred_username
OAUTH_PICTURE_CLAIM=picture
OAUTH_ALLOWED_DOMAINS=example.com



#############
#
# Redis/Valkey
#
#############

#############
#
# Database
#
#############

DATABASE_URL="postgresql://dbuser:dbpassword@self-postgres:5432/selfai"

REDIS_URL = "redis://self-valkey:6379/0"
ENABLE_WEBSOCKET_SUPPORT=true
#WEBSOCKET_MANAGER="redis"
#WEBSOCKET_REDIS_URL="redis://self-valkey:6379/0"


#############
#
# RAG
#
#############

RAG_EMBEDDING_ENGINE="openai"
#RAG_EMBEDDING_MODEL="embed"
RAG_OPENAI_API_BASE_URL="http://self-llamolotl:8080/v1"
RAG_TOP_K=5
RAG_TOP_K_RERANKER=5
RAG_RELEVANCE_THRESHOLD=2.5
ENABLE_RAG_WEB_SEARCH=true
RAG_WEB_SEARCH_ENGINE="duckduckgo"
RAG_WEB_SEARCH_RESULT_COUNT=5
RAG_WEB_SEARCH_CONCURRENT_REQUESTS=5


#############
#
# Vector Database
#
#############

VECTOR_DB=qdrant
QDRANT_URI="http://self-qdrant:6333"
QDRANT_ON_DISK=false
QDRANT_GRPC_PORT=6334
ENABLE_QDRANT_MULTITENANCY_MODE=True

#############
#
# Llamolotl
#
############

LLAMOLOTL_BASE_URLS=http://self-llamolotl:8080

#############
#
# Ollama
#
############

OLLAMA_BASE_URL=http://self-ollama:11434


#############
#
# SearXNG
#
############

SEARXNG_QUERY_URL="https://search.example.com/search?q=<query>"

#############
#
# RAG Engine
#
############

RAG_WEB_LOADER_ENGINE="firecrawl"
FIRECRAWL_API_BASE_URL="https://api.firecrawl.dev"
FIRECRAWL_API_KEY=""

#############
#
# Speech-to-Text
#
#############

AUDIO_STT_ENGINE=openai
AUDIO_STT_OPENAI_API_BASE_URL=http://self-faster-whisper:8890/v1
AUDIO_STT_OPENAI_API_KEY=sk-placeholder
AUDIO_STT_MODEL=whisper-1

#############
#
# Text-to-Speech
#
#############

AUDIO_TTS_ENGINE=openai
AUDIO_TTS_OPENAI_API_BASE_URL=http://self-kokoro:8880/v1
AUDIO_TTS_OPENAI_API_KEY=sk-placeholder
AUDIO_TTS_MODEL=kokoro
AUDIO_TTS_VOICE=af_jessica
